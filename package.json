{
    "name": "confuse-auth-middleware",
    "version": "1.0.0",
    "description": "ConFuse Auth Middleware - Auth0-based authentication for all microservices",
    "type": "module",
    "main": "dist/index.js",
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "build": "tsc",
        "start": "node dist/index.js",
        "lint": "eslint \"src/**/*.{ts,js}\"",
        "lint:fix": "eslint \"src/**/*.{ts,js}\" --fix",
        "test": "vitest",
        "prisma:generate": "prisma generate",
        "prisma:push": "prisma db push",
        "test:grpc": "tsx scripts/test-grpc.ts"
    },
    "dependencies": {
        "@grpc/grpc-js": "^1.14.3",
        "@grpc/proto-loader": "^0.8.0",
        "@prisma/client": "^5.7.1",
        "confuse-common": "file:../shared-middleware/typescript/confuse-common",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "helmet": "^7.1.0",
        "ioredis": "^5.3.0",
        "jose": "^5.1.0",
        "redis": "^5.10.0",
        "winston": "^3.11.0"
    },
    "devDependencies": {
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/node": "^20.10.0",
        "@types/redis": "^4.0.10",
        "@typescript-eslint/eslint-plugin": "^8.59.1",
        "@typescript-eslint/parser": "^8.59.1",
        "eslint": "^8.56.0",
        "prisma": "^5.7.1",
        "tsx": "^4.7.0",
        "typescript": "^6.0.0",
        "vitest": "^4.1.5"
    },
    "engines": {
        "node": ">=24.0.0"
    }
}
