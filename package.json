{
    "name": "confuse-auth-middleware",
    "version": "1.0.0",
    "description": "ConFuse Auth Middleware - Auth0-based authentication for all microservices",
    "type": "module",
    "main": "dist/index.js",
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "build": "tsc",
        "start": "node dist/index.js",
        "lint": "eslint \"src/**/*.{ts,js}\"",
        "lint:fix": "eslint \"src/**/*.{ts,js}\" --fix",
        "test": "vitest",
        "prisma:generate": "prisma generate",
        "prisma:push": "prisma db push",
        "test:grpc": "tsx scripts/test-grpc.ts"
    },
    "dependencies": {
        "@grpc/grpc-js": "^1.14.4",
        "@grpc/proto-loader": "^0.8.1",
        "@prisma/adapter-pg": "^7.8.0",
        "@prisma/client": "^7.8.0",
        "cors": "^2.8.6",
        "dotenv": "^17.4.2",
        "express": "^5.2.1",
        "helmet": "^8.2.0",
        "ioredis": "^5.11.1",
        "jose": "^6.2.3",
        "pg": "^8.22.0",
        "redis": "^6.0.0",
        "winston": "^3.19.0"
    },
    "devDependencies": {
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/node": "^26.0.0",
        "@types/pg": "^8.20.0",
        "@types/redis": "^4.0.11",
        "@typescript-eslint/eslint-plugin": "^8.61.1",
        "@typescript-eslint/parser": "^8.61.1",
        "eslint": "^10.5.0",
        "prisma": "^7.8.0",
        "tsx": "^4.22.4",
        "typescript": "^6.0.3",
        "vitest": "^4.1.9"
    },
    "engines": {
        "node": ">=24.0.0"
    }
}
